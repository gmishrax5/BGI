# ============================================================================
# TRUSTIFY - Environment Variables Template
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or any real environment variables to git
# ============================================================================

# ============================================================================
# SMART CONTRACT ADDRESSES (Get from deployment)
# ============================================================================
NEXT_PUBLIC_DOCUMENT_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_ACCESS_CONTROL_ADDRESS=0x...

# ============================================================================
# BLOCKCHAIN CONFIGURATION
# ============================================================================
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology/
NEXT_PUBLIC_EXPLORER_URL=https://www.oklink.com/amoy

# ============================================================================
# IPFS / PINATA CONFIGURATION
# ============================================================================
NEXT_PUBLIC_PINATA_KEY=your_pinata_key_here
NEXT_PUBLIC_PINATA_GATEWAY=gateway.pinata.cloud

# ============================================================================
# WEB3MODAL CONFIGURATION
# ============================================================================
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ============================================================================
# APPLICATION MODE
# ============================================================================
# Set to 'true' to use mock data without deployed contracts
# Set to 'false' to use real blockchain interactions
NEXT_PUBLIC_DEMO_MODE=true

# ============================================================================
# OPTIONAL: Analytics & Monitoring
# ============================================================================
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=
