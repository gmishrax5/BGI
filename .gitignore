# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================================================
# ENVIRONMENT & SECRETS - NEVER COMMIT
# ============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env.*.example
.env.secret
*.key
*.pem
*.p12
*.pfx

# ============================================================================
# DEPENDENCIES
# ============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================================================
# BUILD & RUNTIME OUTPUT
# ============================================================================
/.next/
/out/
/build/
/dist/
*.tsbuildinfo

# ============================================================================
# TESTING
# ============================================================================
/coverage
*.lcov
.nyc_output

# ============================================================================
# IDE & EDITOR CONFIG
# ============================================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ============================================================================
# DEBUGGING & LOGS
# ============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
debug.log
lerna-debug.log*
*.log

# ============================================================================
# OS FILES
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ============================================================================
# PRODUCTION FILES (VERCEL)
# ============================================================================
.vercel
.vercel/*.json

# ============================================================================
# LOCAL DEVELOPMENT
# ============================================================================
.cache
.temp
tmp/
*.tmp

# ============================================================================
# GENERATED FILES
# ============================================================================
next-env.d.ts
